# ═══════════════════════════════════════════
# BugBot — Claude TG Bot (CLI) via worktree workflow
# ═══════════════════════════════════════════

# Bot language: "en" or "ru"
BOT_LANG=en

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# ── Users ─────────────────────────────────
# Telegram user IDs (comma-separated). Find yours: /id in the bot
ALLOWED_USERS=

# Mapping userId -> GitHub/GitLab username (for PR/MR reviewers and co-author)
# Format: telegramId:username,...
USER_GITHUB_MAP=

# ── Project ───────────────────────────────
# Path to the project git repository (required!)
PROJECT_DIR=/var/www/my-project

# Target branch for PRs
PR_TARGET_BRANCH=dev

# Git platform: "github" or "gitlab"
GIT_PLATFORM=github

# ── Worktree mode ─────────────────────────
# Creates git worktree + branch for each task → push → PR
WORKTREE_MODE=true

# Base directory for worktrees
# WORKTREE_BASE_DIR=/var/www/my-project/.worktrees

# Branch name prefix
BRANCH_PREFIX=bugbot/

# ── Claude CLI ────────────────────────────
CLAUDE_BIN=claude
MODEL=
SYSTEM_PROMPT=

# Max agent turns (0 = unlimited)
MAX_TURNS=0

# Timeout in seconds
TIMEOUT_SEC=300

# ── Rate limit ────────────────────────────
RATE_LIMIT_MESSAGES=20
RATE_LIMIT_WINDOW=60

# ── Merge (admin commands) ────────────────
# Telegram ID of admin who can run /merge_dev and /merge_prod
MERGE_ADMIN_ID=

# /merge_dev merges PR_TARGET_BRANCH into this branch
MERGE_DEV_BRANCH=dev

# /merge_prod merges MERGE_DEV_BRANCH into this branch
MERGE_PROD_BRANCH=main

# ── Chats ─────────────────────────────────
# Max concurrent sessions across all users
MAX_ACTIVE_CHATS=3
